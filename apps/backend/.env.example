# Database
# In development we use postgres to be able to run migrations
# In production change according to your infrastructure
# Connection pool parameters (recommended for production):
# - connection_limit: Max connections per instance (default: 10, formula: num_cpus * 2 + spindles)
# - pool_timeout: Max time to get connection from pool in seconds (default: 10)
# - connect_timeout: Max time to establish connection in seconds (default: 5)
# Example with connection pool and timeouts:
# postgresql://user:password@localhost:5432/database_name?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10&statement_timeout=10000
# - statement_timeout: Query execution timeout in milliseconds (default: disabled, recommended: 10000)
DATABASE_URL="postgresql://user:password@localhost:5432/database_name?schema=public&statement_timeout=10000"

# JWT
# Access token expires in 1 day
# Tokens are stored in httpOnly cookies for security
# Users will need to re-authenticate after this time
JWT_SECRET="your-super-secure-jwt-secret-key-change-me"
JWT_EXPIRATION="1d"

# Account Lockout (failed login attempts)
# Number of failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
ACCOUNT_LOCKOUT_DURATION=15

# Password History
# Number of previous passwords to prevent reuse (recommended: 5-10)
PASSWORD_HISTORY_COUNT=5

# CSRF Protection
# SameSite cookie attribute: 'strict' (most secure) or 'lax' (allows OAuth/external redirects)
# Use 'strict' for applications without OAuth, 'lax' if you need OAuth flows
CSRF_SAME_SITE=strict

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# CORS - Allowed origins (comma-separated for multiple environments)
# Example: http://localhost:3000,https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:3000

# Proxy Configuration (for production behind load balancer/proxy)
# Set TRUST_PROXY=true only when behind a trusted reverse proxy (nginx, cloudflare, etc)
# TRUSTED_PROXIES should be comma-separated list of proxy IP addresses
# Example: TRUSTED_PROXIES=10.0.0.1,10.0.0.2
TRUST_PROXY=false
TRUSTED_PROXIES=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_USE_SSL=false
MINIO_BUCKET=your-bucket-name

# Email (configure with your SMTP provider)
# Port 465 uses implicit TLS/SSL (secure: true)
# Port 587 uses STARTTLS (secure: false, but upgrades to TLS)
# Port 25 is plain SMTP (may use STARTTLS)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM="Your App Name <noreply@example.com>"
# Set to 'false' only in development if using self-signed certificates
# ALWAYS use 'true' in production for security
EMAIL_REJECT_UNAUTHORIZED=true

# Redis (Cache)
# Enable Redis for caching (recommended for production)
# Set to 'true' to use Redis, 'false' to use in-memory cache
REDIS_ENABLED=false
# Redis connection settings (only used if REDIS_ENABLED=true)
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: Full Redis URL (overrides HOST and PORT if provided)
# REDIS_URL=redis://localhost:6379
# Optional: Redis password (if authentication is enabled)
# REDIS_PASSWORD=your-redis-password
# Optional: Redis database number (default: 0)
# REDIS_DB=0
